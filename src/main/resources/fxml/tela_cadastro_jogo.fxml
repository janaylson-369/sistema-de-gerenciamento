<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="696.0" prefWidth="759.0" styleClass="mainFxmlClass" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.ingressosjogos.controller.Tela_cadastro_jogoController">
    <stylesheets>
        <URL value="@/styles/tela_cadastro_jogo.css" />
    </stylesheets>
    <children>
        <ScrollPane fitToWidth="true" layoutX="-7.2" prefHeight="667.0" prefWidth="506.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="-7.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #f4f4f4;">
                    <padding>
                        <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
                    </padding>
                    <children>
                        <Label text="Painel Admin: Cadastrar Nova Partida" textFill="#333333">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ddd; -fx-border-radius: 8;">
                            <Label text="🏟️ Dados do Estádio" textFill="#555555">
                                <font><Font name="System Bold" size="14.0" /></font>
                            </Label>
                            <TextField fx:id="campoNomeEstadio" promptText="Nome do Estádio (ex: Maracanã)" />
                            <TextField fx:id="campoLocalEstadio" promptText="Localização / Cidade (ex: Rio de Janeiro - RJ)" />
                            <TextField fx:id="campoCapacidadeEstadio" promptText="Capacidade Total (ex: 50000)" />
                        </VBox>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ddd; -fx-border-radius: 8;">
                            <Label text="⚽ Dados dos Times" textFill="#555555">
                                <font><Font name="System Bold" size="14.0" /></font>
                            </Label>
                            <TextField fx:id="campoTimeCasa" promptText="Nome do Time da Casa" />
                            <TextField fx:id="campoTimeFora" promptText="Nome do Time de Fora" />
                        </VBox>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ddd; -fx-border-radius: 8;">
                            <Label text="📅 Dados da Partida" textFill="#555555">
                                <font><Font name="System Bold" size="14.0" /></font>
                            </Label>
                            <HBox spacing="15.0">
                                <DatePicker fx:id="campoDataJogo" prefWidth="200.0" promptText="Data do Jogo" />
                                <TextField fx:id="campoHoraJogo" prefWidth="180.0" promptText="Horário (HH:MM)" />
                            </HBox>
                        </VBox>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ddd; -fx-border-radius: 8;">
                            <Label text="🎟️ Dados dos Ingressos" textFill="#555555">
                                <font><Font name="System Bold" size="14.0" /></font>
                            </Label>
                            <TextField fx:id="campoPrecoIngresso" promptText="Preço Base (R$)" />
                        </VBox>
                        
                        <Button mnemonicParsing="false" onAction="#salvarCadastroCompleto" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 5;" text="Salvar Tudo e Gerar Ingressos" />
                        <Button mnemonicParsing="false" onAction="#voltarParaJogos" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 8 15;" text="⬅️ Voltar para Jogos" />
                        
                        <Label fx:id="labelMensagemAdmin" text="Preencha os dados e clique em salvar." textFill="#888888" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
